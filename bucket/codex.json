{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "0.133.0",
   "description": "A coding agent from OpenAI that runs locally on your computer.",
   "homepage": "https://github.com/openai/codex",
   "license": {
      "identifier": "Apache-2.0",
      "url": "https://github.com/openai/codex/blob/master/LICENSE.md"
   },
   "architecture": {
      "64bit": {
         "url": "https://registry.npmjs.org/@openai/codex/-/codex-0.133.0-win32-x64.tgz",
         "hash": "sha1:6a5c1094380a2308c32962571ea4087cd541618b",
         "extract_dir": "package\\vendor\\x86_64-pc-windows-msvc"
      },
      "arm64": {
         "url": "https://registry.npmjs.org/@openai/codex/-/codex-0.133.0-win32-arm64.tgz",
         "hash": "sha1:9decf4d726a946603225878331bc04829f2af4ae",
         "extract_dir": "package\\vendor\\aarch64-pc-windows-msvc"
      }
   },
   "bin": [
      [
         "bin\\codex.exe",
         "codex"
      ]
   ],
   "persist": "config",
   "env_set": {
      "CODEX_HOME": "$dir\\config"
   },
   "checkver": {
      "url": "https://registry.npmjs.com/@openai/codex",
      "jsonpath": "$.dist-tags.latest"
   },
   "autoupdate": {
      "architecture": {
         "64bit": {
            "url": "https://registry.npmjs.org/@openai/codex/-/codex-$version-win32-x64.tgz",
            "hash": {
               "url": "https://registry.npmjs.org/@openai/codex/$version-win32-x64",
               "jsonpath": "$.dist.shasum"
            }
         },
         "arm64": {
            "url": "https://registry.npmjs.org/@openai/codex/-/codex-$version-win32-arm64.tgz",
            "hash": {
               "url": "https://registry.npmjs.org/@openai/codex/$version-win32-arm64",
               "jsonpath": "$.dist.shasum"
            }
         }
      }
   }
}
