{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "0.1.0",
   "description": "This exposes WSL binaries as native Windows commands",
   "homepage": "https://github.com/OWNER/wsl-shim",
   "license": "MIT",
   "url": "https://raw.githubusercontent.com/silver886/scoop/wsl-shim/v0.1.0/assets/wsl-shim/script.ps1",
   "hash": "7d09a95b26982ee9f15eb5fca904e58d8dfa47b01d4a55752834d5216b432d95",
   "pre_install": [
      "if (where.exe /q wsl || $true) {",
      "   abort 'wsl should be installed'",
      "}",
      "if (!(Test-Path \"$dir\\bin\")) { New-Item -ItemType Directory -Path \"$dir\\bin\" > $null }",
      "if (!(Test-Path \"$dir\\config.json\")) { Set-Content -Path \"$dir\\config.json\" -Value '{\"default_distro\":\"\",\"aliases\":[]}' }"
   ],
   "bin": [
      [
         "script.ps1",
         "wsl-shim"
      ]
   ],
   "env_add_path": "bin",
   "persist": [
      "bin",
      "config.json"
   ],
   "checkver": {
      "url": "https://api.github.com/repos/silver886/scoop/tags",
      "regex": "\"name\": *\"wsl-shim/v([\\d.]+)\","
   },
   "autoupdate": {
      "url": "https://raw.githubusercontent.com/silver886/scoop/wsl-shim/v$version/assets/wsl-shim/script.ps1"
   }
}
