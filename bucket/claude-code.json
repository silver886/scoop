{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "2.1.137",
   "description": "An agentic coding tool that lives in your terminal, understands your codebase, and helps you code faster by executing routine tasks, explaining complex code, and handling git workflows -- all through natural language commands.",
   "homepage": "https://github.com/anthropics/claude-code",
   "license": {
      "identifier": "Proprietary",
      "url": "https://github.com/anthropics/claude-code/blob/master/LICENSE.md"
   },
   "architecture": {
      "64bit": {
         "url": "https://registry.npmjs.org/@anthropic-ai/claude-code-win32-x64/-/claude-code-win32-x64-2.1.137.tgz",
         "hash": "sha1:9bf612720aa0aabc529aca2baef5cbb0a9630c52"
      },
      "arm64": {
         "url": "https://registry.npmjs.org/@anthropic-ai/claude-code-win32-arm64/-/claude-code-win32-arm64-2.1.137.tgz",
         "hash": "sha1:92b8665425918c8014eac8676e205618b94e8b68"
      }
   },
   "extract_dir": "package",
   "bin": [
      [
         "claude.exe",
         "claude"
      ]
   ],
   "persist": "config",
   "env_set": {
      "CLAUDE_CONFIG_DIR": "$dir\\config"
   },
   "checkver": {
      "url": "https://registry.npmjs.com/@anthropic-ai/claude-code",
      "jsonpath": "$.dist-tags.latest"
   },
   "autoupdate": {
      "architecture": {
         "64bit": {
            "url": "https://registry.npmjs.org/@anthropic-ai/claude-code-win32-x64/-/claude-code-win32-x64-$version.tgz",
            "hash": {
               "url": "https://registry.npmjs.org/@anthropic-ai/claude-code-win32-x64/$version",
               "jsonpath": "$.dist.shasum"
            }
         },
         "arm64": {
            "url": "https://registry.npmjs.org/@anthropic-ai/claude-code-win32-arm64/-/claude-code-win32-arm64-$version.tgz",
            "hash": {
               "url": "https://registry.npmjs.org/@anthropic-ai/claude-code-win32-arm64/$version",
               "jsonpath": "$.dist.shasum"
            }
         }
      }
   }
}
